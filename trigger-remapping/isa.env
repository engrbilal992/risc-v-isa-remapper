# RISC-V ISA Remapping — Central Config
# Read in bash:   source config.sh  (config.sh loads this file)
# Read in Python: from config import cfg; cfg['ISA_MAP']

ISA_MAP=/etc/isa/map
QEMU_REL=../phase1/qemu-8.2.0/build/qemu-riscv64
QEMU_SYSTEM_REL=../phase1/qemu-8.2.0/build/qemu-system-riscv64
QEMU_BIOS_REL=../phase1/qemu-8.2.0/pc-bios/opensbi-riscv64-generic-fw_dynamic.bin
ALPINE_IMG_REL=alpine/alpine-riscv64.img
ALPINE_KERNEL_REL=alpine/kernel_extract/boot/vmlinux-6.19.11+deb14-riscv64
ALPINE_INITRD_REL=alpine/initramfs.cpio.gz
DEMO_DIR_REL=riscv_demo
